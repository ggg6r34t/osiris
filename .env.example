# Optional backend configuration for the Osiris API / web UI.
# Copy to .env (gitignored) or export in your shell before running ./run.sh.

# --- Brand Abuse (regex) tool — internal Panda dataset API (VPN required) ---
# Nothing here is committed; set these locally to enable the tool.
OSIRIS_PANDA_URL=
OSIRIS_PANDA_LOGIN=
OSIRIS_PANDA_KEY=

# --- Optional enrichment API keys (features degrade gracefully without them) ---
ABUSEIPDB_API_KEY=
SECURITYTRAILS_API_KEY=
IPINFO_TOKEN=
VIRUSTOTAL_API_KEY=
# (urlscan.io search and reverse-IP work without a key, just rate-limited)

# --- VIP investigation (protective-intelligence exposure) ---
# Have I Been Pwned breach lookups (paid API key). Without it the VIP
# service-discoverability score falls back to profile-resolution only.
HAVEIBEENPWNED_API_KEY=
# Brave Search API (free tier available) adds name-mention volume to the VIP
# online-presence score. Without it, presence uses account footprint only.
BRAVE_SEARCH_API_KEY=

# --- Optional alerting for monitoring (new lookalikes) — off unless set ---
# Telegram: create a bot via @BotFather for the token, get your chat id from
# @userinfobot (or the getUpdates API). Both must be set to enable Telegram.
OSIRIS_TELEGRAM_BOT_TOKEN=
OSIRIS_TELEGRAM_CHAT_ID=
# Generic webhook: Osiris POSTs {"text": "...", "data": {...}} here. Point it at
# an internal endpoint to keep alert data off external services.
OSIRIS_ALERT_WEBHOOK_URL=

# --- Optional network defaults (also settable in the Settings tab) ---
# OSIRIS_USER_AGENT=Osiris/1.0
# OSIRIS_REQUEST_TIMEOUT=30
# OSIRIS_VERIFY_TLS=true
# OSIRIS_HTTP_PROXY=
# OSIRIS_HTTPS_PROXY=
