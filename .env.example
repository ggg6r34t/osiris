# Optional backend configuration for the Osiris API / web UI.
# Copy to .env (gitignored) or export in your shell before running ./run.sh.

# --- Brand Abuse (regex) tool — internal Panda dataset API (VPN required) ---
# Nothing here is committed; set these locally to enable the tool.
OSIRIS_PANDA_URL=
OSIRIS_PANDA_LOGIN=
OSIRIS_PANDA_KEY=

# --- Optional enrichment API keys (features degrade gracefully without them) ---
ABUSEIPDB_API_KEY=
SECURITYTRAILS_API_KEY=
IPINFO_TOKEN=

# --- Optional network defaults (also settable in the Settings tab) ---
# OSIRIS_USER_AGENT=Osiris/1.0
# OSIRIS_REQUEST_TIMEOUT=30
# OSIRIS_VERIFY_TLS=true
# OSIRIS_HTTP_PROXY=
# OSIRIS_HTTPS_PROXY=
